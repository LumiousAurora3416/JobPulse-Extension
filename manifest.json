{
  "manifest_version": 3,
  "name": "JobPulse · 招聘同步飞书",
  "version": "1.1.0",
  "description": "将当前页岗位标题与链接同步到飞书多维表格",
  "action": {
    "default_popup": "popup.html",
    "default_title": "同步到飞书"
  },
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["https://open.feishu.cn/*"]
}
